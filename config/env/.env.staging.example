NODE_ENV=staging
APP_ENV=staging
APP_URL=https://staging.procuredesk.example.com
API_URL=https://staging.procuredesk.example.com
PORT=3000
DATABASE_URL=postgres://procuredesk:${POSTGRES_PASSWORD}@postgres.internal:5432/procuredesk_staging
REDIS_URL=redis://redis:6379
SESSION_SECRET=replace-with-64-char-secret
CSRF_SECRET=replace-with-64-char-secret
CSRF_COOKIE_NAME=procuredesk_csrf
SESSION_COOKIE_NAME=procuredesk_session
SESSION_TTL_HOURS=8
LOGIN_RATE_LIMIT_ATTEMPTS=10
LOGIN_RATE_LIMIT_WINDOW_MINUTES=15
LOGIN_RATE_LIMIT_LOCKOUT_MINUTES=15
BOOTSTRAP_TENANT_NAME=ProcureDesk Staging
BOOTSTRAP_TENANT_CODE=STAGING
BOOTSTRAP_TENANT_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_PLATFORM_ADMIN_EMAIL=platform@example.com
MS_GRAPH_TENANT_ID=
MS_GRAPH_CLIENT_ID=
MS_GRAPH_CLIENT_SECRET=
MS_GRAPH_SENDER_MAILBOX=procuredesk-notifications@example.com
PRIVATE_STORAGE_DRIVER=local
PRIVATE_STORAGE_ROOT=/var/lib/procuredesk/private
AZURE_BLOB_CONNECTION_STRING=
AZURE_BLOB_CONTAINER_NAME=procuredesk-private
IMPORT_MAX_FILE_BYTES=26214400
