NODE_ENV=development
APP_ENV=local
APP_URL=http://localhost:5175
API_URL=http://localhost:3100
VITE_API_URL=http://localhost:3100/api/v1
PORT=3100

DATABASE_URL=postgres://procuredesk:procuredesk@localhost:55433/procuredesk
REDIS_URL=redis://localhost:56379

SESSION_SECRET=local-session-secret-change-me-000000000000
CSRF_SECRET=local-csrf-secret-change-me-00000000000000
SESSION_COOKIE_NAME=procuredesk_session
CSRF_COOKIE_NAME=procuredesk_csrf
SESSION_TTL_HOURS=8

LOGIN_RATE_LIMIT_ATTEMPTS=10
LOGIN_RATE_LIMIT_WINDOW_MINUTES=15
LOGIN_RATE_LIMIT_LOCKOUT_MINUTES=15

BOOTSTRAP_TENANT_NAME="Local ProcureDesk Tenant"
BOOTSTRAP_TENANT_CODE=local
BOOTSTRAP_TENANT_ADMIN_EMAIL=tenant.admin@procuredesk.local
BOOTSTRAP_PLATFORM_ADMIN_EMAIL=platform.admin@procuredesk.local

PRIVATE_STORAGE_DRIVER=local
PRIVATE_STORAGE_ROOT=/tmp/procuredesk/private
IMPORT_MAX_FILE_BYTES=26214400

# Optional for local development. Required for production notification delivery.
# MS_GRAPH_TENANT_ID=
# MS_GRAPH_CLIENT_ID=
# MS_GRAPH_CLIENT_SECRET=
# MS_GRAPH_SENDER_MAILBOX=
