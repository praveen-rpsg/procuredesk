{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 3,
  "graphTooltip": 0,
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "id": 1,
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_total{app=~\"procuredesk-api\"}[5m]))",
          "legendFormat": "requests/sec"
        }
      ],
      "title": "API Request Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "id": 2,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_request_duration_seconds_bucket{app=~\"procuredesk-api\"}[5m])) by (le)) * 1000",
          "legendFormat": "p95 latency"
        }
      ],
      "title": "API P95 Latency",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "id": 3,
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_total{app=~\"procuredesk-api\",status=~\"5..\"}[5m])) / clamp_min(sum(rate(http_server_requests_total{app=~\"procuredesk-api\"}[5m])), 1)",
          "legendFormat": "5xx rate"
        }
      ],
      "title": "API Error Rate",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "id": 4,
      "targets": [
        {
          "expr": "sum(procuredesk_outbox_events{status=\"pending\"})",
          "legendFormat": "pending"
        },
        {
          "expr": "sum(procuredesk_outbox_events{status=\"failed\"})",
          "legendFormat": "failed"
        }
      ],
      "title": "Outbox Backlog",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "id": 5,
      "targets": [
        {
          "expr": "sum(procuredesk_jobs{queue=~\"imports|exports\",status=\"waiting\"}) by (queue)",
          "legendFormat": "{{queue}} waiting"
        },
        {
          "expr": "sum(procuredesk_jobs{queue=~\"imports|exports\",status=\"failed\"}) by (queue)",
          "legendFormat": "{{queue}} failed"
        }
      ],
      "title": "Import And Export Queues",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "id": 6,
      "targets": [
        {
          "expr": "sum(procuredesk_notification_jobs{status=\"failed\"})",
          "legendFormat": "failed"
        },
        {
          "expr": "sum(procuredesk_notification_jobs{status=\"sent\"})",
          "legendFormat": "sent"
        }
      ],
      "title": "Notification Delivery",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "id": 7,
      "targets": [
        {
          "expr": "pg_stat_database_numbackends{datname=~\"procuredesk.*\"}",
          "legendFormat": "connections"
        }
      ],
      "title": "PostgreSQL Connections",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "unit": "percent" }, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "id": 8,
      "targets": [
        {
          "expr": "redis_memory_used_bytes / redis_memory_max_bytes * 100",
          "legendFormat": "redis memory"
        }
      ],
      "title": "Redis Memory Utilization",
      "type": "timeseries"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["procuredesk", "production"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Prometheus",
        "name": "DS_PROMETHEUS",
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      }
    ]
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timezone": "browser",
  "title": "ProcureDesk Production Overview",
  "uid": "procuredesk-production-overview",
  "version": 1,
  "weekStart": ""
}
